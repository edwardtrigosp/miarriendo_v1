# Límites de subida de archivos (varias fotos por propiedad)
php_value upload_max_filesize 5M
php_value post_max_size 30M

# Activar motor de reescritura de URLs
RewriteEngine On

# Si el archivo o carpeta existe (css, js, imágenes), servirlo directamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás se redirige al front controller (router)
RewriteRule ^ index.php [QSA,L]
