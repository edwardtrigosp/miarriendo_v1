# Copia este archivo a ".env" y completa los valores reales.
# El .env NUNCA se versiona (está en .gitignore).

# Entorno de ejecución:
#   development -> muestra los errores en pantalla (solo local)
#   production  -> oculta los errores al usuario y los registra en el log
APP_ENV=production

# Base de datos (MySQL)
DB_HOST=db
DB_PORT=3306
DB_NAME=miarriendo
DB_USER=miarriendo
DB_PASSWORD=cambia_esta_clave
DB_ROOT_PASSWORD=cambia_esta_clave_root

# Opcional (no se usa con OpenStreetMap, se conserva por compatibilidad)
GOOGLE_MAPS_API_KEY=
